# Supabase — 값은 Supabase 대시보드 → Settings → API 에서 복사해 .env.local 에 채우세요.
# URL은 공개값(프로젝트 ref rxeemalvzovgzruwegnp). anon/service 키는 비밀입니다.
NEXT_PUBLIC_SUPABASE_URL=https://rxeemalvzovgzruwegnp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 데이터 수집 API (Phase 1a 부트스트랩 — 나중에 채움)
WORKNET_API_KEY=
DATA_GO_KR_API_KEY=
